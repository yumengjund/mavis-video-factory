{
  "name": "bilibili_ingestion_runtime",
  "version": "1.5.2-hardened-patch1",
  "platform": "bilibili",
  "base_search_url": "https://search.bilibili.com/all?keyword={keyword}",
  "capabilities": {
    "keyword_search": {"enabled": true, "max_results": 50},
    "video_download": {"enabled": true, "format": "mp4", "max_bitrate_mbps": 12},
    "metadata_extraction": {"fields": ["title", "duration", "view_count", "danmaku_count", "favorite_count", "coin_count", "author_mid", "bvid", "tags"]},
    "license_estimation": {"method": "soft_heuristic", "indicators": ["watermark_presence", "official_creator", "copyright_flag"], "risk_score_range": [0, 100]},
    "format_normalization": {"target_codec": "h264", "target_fps": 30, "target_resolution": "1080p", "normalize_audio": true}
  },
  "rate_limit": {"requests_per_minute": 15, "burst": 5}
}
