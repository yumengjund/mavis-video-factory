{
  "name": "weibo_ingestion_runtime",
  "version": "1.5.2-hardened-patch1",
  "platform": "weibo",
  "base_search_url": "https://s.weibo.com/video?q={keyword}",
  "capabilities": {
    "keyword_search": {"enabled": true, "max_results": 50},
    "video_download": {"enabled": true, "format": "mp4", "max_bitrate_mbps": 8},
    "metadata_extraction": {"fields": ["title", "duration", "play_count", "repost_count", "comment_count", "like_count", "author_uid", "topic_tags"]},
    "license_estimation": {"method": "soft_heuristic", "indicators": ["watermark_presence", "verified_account", "original_post"], "risk_score_range": [0, 100]},
    "format_normalization": {"target_codec": "h264", "target_fps": 30, "target_resolution": "1080p", "normalize_audio": true}
  },
  "rate_limit": {"requests_per_minute": 10, "burst": 3}
}
