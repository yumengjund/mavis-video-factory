{
  "name": "xiaohongshu_ingestion_runtime",
  "version": "1.5.2-hardened-patch1",
  "platform": "xiaohongshu",
  "base_search_url": "https://www.xiaohongshu.com/search_result?keyword={keyword}",
  "capabilities": {
    "keyword_search": {"enabled": true, "max_results": 50},
    "video_download": {"enabled": true, "format": "mp4", "max_bitrate_mbps": 8},
    "metadata_extraction": {"fields": ["title", "duration", "like_count", "collect_count", "comment_count", "author_id", "tags", "location"]},
    "license_estimation": {"method": "soft_heuristic", "indicators": ["watermark_presence", "author_certified", "original_note"], "risk_score_range": [0, 100]},
    "format_normalization": {"target_codec": "h264", "target_fps": 30, "target_resolution": "1080p", "normalize_audio": true}
  },
  "rate_limit": {"requests_per_minute": 10, "burst": 3}
}
